# =============================================================
# CutBook — Variables d'environnement
# Copier en .env et remplir avec les vraies valeurs (ne JAMAIS commit .env)
# =============================================================

# --- Database ---
# Dev local : voir docker-compose.yml pour les credentials
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=""

# Production (Neon) — format identique avec ?sslmode=require a la fin
# DATABASE_URL=""

# --- BetterAuth ---
# Generer avec : openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Bootstrap admin optionnel : emails autorises a entrer dans /admin meme sans role ADMIN en BDD.
# A utiliser pour promouvoir le premier compte, puis privilegier le role ADMIN.
ADMIN_EMAILS=""

# Google OAuth (Console Google Cloud > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stripe ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- Email (Resend) ---
# Dev local recommande : smtp + Mailpit via docker-compose (UI http://localhost:8025)
# Production recommande : resend
EMAIL_PROVIDER="smtp"
RESEND_API_KEY="re_..."
EMAIL_FROM="CutBook <noreply@cutbook.com>"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
